# ─── SEMrush ───────────────────────────────────────────────
SEMRUSH_API_KEY=ad1ea0849861b1970060bc79e68b1e64

# Target domain to track (no https://)
DOMAIN=www.cawarden.co.uk

# SEMrush database (uk = Google UK, us = Google US, etc.)
# Full list: https://developer.semrush.com/api/basics/databases/
SEMRUSH_DATABASE=uk

# ─── Position Tracking (optional — enables mobile rankings) ─
# Create a project at https://www.semrush.com/projects/
# then paste the numeric project ID here.
# If left blank, the tracker falls back to Organic Research
# (desktop rankings only).
SEMRUSH_PROJECT_ID=

# ─── Google Sheets ──────────────────────────────────────────
# The spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Name of the sheet tab to update
GOOGLE_SHEET_NAME=Updated Sheet

# Service account credentials (from Google Cloud Console)
# Create a service account, download the JSON key, then:
#   - share the spreadsheet with the service account email
#   - paste the values below
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Paste the private key exactly as-is (including \n newlines)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Output ─────────────────────────────────────────────────
# Path for the CSV tracking file (relative to project root)
CSV_OUTPUT_PATH=./data/rankings.csv

# ─── Safety guards ───────────────────────────────────────────
# Set to true to skip all API calls and use mock data.
# Use this to test the full pipeline without spending API units.
DRY_RUN=false
